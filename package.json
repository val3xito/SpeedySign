{
  "name": "speedysign",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --web",
    "dev": "concurrently -n \"frontend,server\" -c \"cyan,yellow\" \"expo start --web\" \"cd server && npm run dev\"",
    "start:prod": "npm run build:web && cd server && npm install && npm start",
    "build:web": "npx dotenv -- expo export -p web",
    "test": "jest --testPathPattern=utils/__tests__",
    "test:watch": "jest --testPathPattern=utils/__tests__ --watch"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.98.0",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-document-picker": "~14.0.8",
    "expo-font": "~14.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-localization": "~17.0.8",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "i18next": "^25.8.13",
    "nativewind": "^4.0",
    "node-forge": "^1.3.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.5.4",
    "react-native": "^0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-web": "^0.21.0",
    "sileo": "^0.1.5",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node-forge": "^1.3.14",
    "@types/react": "~19.1.0",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "ts-jest": "^29.4.11",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/utils/__tests__/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^react-native$": "react-native"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "jsx": "react"
          }
        }
      ]
    }
  },
  "private": true
}
